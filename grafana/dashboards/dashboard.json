      },
      "id": 1,
      "title": "Nginx Active Connections",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "nginx_connections_active",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "title": "Total Requests Handled",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "nginx_connections_accepted",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "title": "Request Rate (1m)",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(nginx_connections_accepted[1m])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "reqps"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 4,
      "title": "Nginx Connection Status Over Time",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "nginx_connections_active",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "expr": "nginx_connections_reading",
          "legendFormat": "Reading",
          "refId": "B"
        },
        {
          "expr": "nginx_connections_writing",
          "legendFormat": "Writing",
          "refId": "C"
        },
        {
          "expr": "nginx_connections_waiting",
          "legendFormat": "Waiting",
          "refId": "D"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 5,
      "title": "Server Host CPU Usage (%)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "Host CPU",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          },
          "unit": "percent"
        }
      }
    }
  ],
